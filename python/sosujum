def main():
    string = "abc"
    string2 = "this is format test: {}".format(10)
    print(string)
    print(string2)

    string3 = "{0} {1} {2}".format(10, 999, 6694)
    print(string3)
    string4 = "{0:d} {1:5d} {2:05d}".format(10, 999, 6694)
    print(string4)
    string5 = "{0:+.2f} {1:+.2f} {2:+.2f}".format(10.5, 999.7, 6694.9)
    print(string5)
    string6 = "하하핳 {0:+f}".format(99999999999999.99999999999999)
    print(string6)
if __name__=="__main__":
        main()
        